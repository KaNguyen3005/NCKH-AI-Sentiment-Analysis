# =========================
# Project Specific (Data & Models)
# LƯU Ý: Git không thể đẩy (push) các file > 100MB, và không nên push model/data
# =========================

# Không push dữ liệu raw và processed
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Không push mô hình (weights rất nặng)
models/baseline/*
models/phobert/*
!models/baseline/.gitkeep
!models/phobert/.gitkeep

# Không push kết quả dự đoán rác, log (có thể giữ lại các file tổng hợp nhỏ nếu muốn)
results/*
!results/experiments_log.csv
!results/.gitkeep

# Không push các file rác khi build LaTeX (nếu viết paper LaTeX)
report/*.aux
report/*.log
report/*.out
report/*.toc
report/*.fls
report/*.fdb_latexmk
report/*.synctex.gz
report/*.bbl
report/*.blg

# Bỏ qua folder figures nếu nó sinh ra quá nhiều ảnh rác, hoặc để lại nếu muốn lưu (hiện đang không ignore figures)

# FastText gốc và cache có thể tái tạo, không đưa lên Git
models/fasttext/*.vec
models/fasttext/*.vec.gz
models/fasttext/*.bin

# Cache mặc định bị ignore
models/fasttext/*.npy
models/fasttext/*.json

# Cho phép commit cache thu gọn dùng chung cho BiLSTM và GRU
!models/fasttext/embedding_matrix.npy
!models/fasttext/word2idx.json
!models/fasttext/fasttext_cache_meta.json

# Không commit checkpoint debug và checkpoint từng lần tune
models/baseline/*_debug_best.pt
models/baseline/bilstm_ft_lr*_best.pt

# Ngoại lệ cuối cùng: commit checkpoint chính thức
!models/baseline/bilstm_best.pt
!models/baseline/gru_best.pt

# PLM debug artifacts
data/figures/*_debug_learning_curve.png